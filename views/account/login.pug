extends ../ui_layout

//- CHANGED TO USE MTURKID INSTEAD OF USERNAME/PASSWORD

block content
  .computer.only.tablet.only.eight.wide.column
    img.ui.fluid.image(src=process.env.SITE_PICTURE)

  .eight.wide.computer.eight.wide.tablet.sixteen.wide.mobile.column
    .ui.card.fluid(style="padding: 20px; margin-top: 90px;")
      h2.ui.header Sign in
      form.ui.form(action='/login', method='POST')
        input(type='hidden', name='_csrf', value=_csrf)
        .field
          label(for='mturkID') Participant ID
          input(type='text', name='mturkID', id='mturkID', placeholder='Enter your Participant ID', required)
        button.ui.large.button.blue(type='submit') Log In
      //- .ui.horizontal.divider
      //-   | Or
      //- .center.aligned.column
      //-   .ui.big.green.labeled.icon.button.signup
      //-     i.signup.icon
      //-     |   Create Account

  // Popup container (hidden by default)
  .ui.basic.modal#studyPopup
    .ui.icon.header
      i.info.circle.icon
      | The study is currently not active.
    .content
      p Sorry, you cannot create a new account right now.
    .actions
      .ui.ok.green.button OK

  script.
    $('.ui.big.green.labeled.icon.button.signup').on('click', function() {
      fetch('/study/status')
        .then(res => res.json())
        .then(data => {
          if (data.active) {
            window.location.href = `/signup${window.location.search}`;
          } else {
            $('#studyPopup').modal('show');
          }
        })
        .catch(err => {
          console.error('Error checking study status:', err);
          window.location.href = `/signup${window.location.search}`;
        });
    });

